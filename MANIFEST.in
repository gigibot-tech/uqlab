include README.md
include LICENSE
include pyproject.toml
include py.typed

# Include all markdown documentation
recursive-include . *.md

# Include configuration files
recursive-include . *.yaml
recursive-include . *.yml
recursive-include . *.json

# Exclude development and build artifacts
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.so
global-exclude .git*
global-exclude .specify

# Exclude test files
prune tests
prune .pytest_cache

# Exclude notebooks and experiments
prune notebooks
prune legacy_experiments
prune benchmarks